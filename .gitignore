# ============================================================
# Evidence safety
# ============================================================

# Block large/raw evidence by default
evidence/**/*.pcap
evidence/**/*.pcapng
evidence/**/*.cap
evidence/**/*.log
evidence/**/*.gz
evidence/**/*.zip
evidence/**/*.tar
evidence/**/*.tar.gz

# Allow small sanitized/sample evidence files
!evidence/**/*sample*.txt
!evidence/**/*sample*.json
!evidence/**/*sample*.log
!evidence/**/*sanitized*.txt
!evidence/**/*sanitized*.json
!evidence/**/*sanitized*.log
!evidence/**/README.md
!evidence/**/notes.md


# ============================================================
# Payloads / offensive artifacts
# ============================================================

payloads/
exploits/
malware/
shells/
reverse-shells/
wordlists/

*.elf
*.exe
*.dll
*.bin
*.sh.bin
*.payload
*.msf


