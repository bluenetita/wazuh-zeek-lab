!**/evidence/**/README.md


# ============================================================
# Zeek runtime files and logs
# ============================================================

/opt/zeek/logs/
/var/log/zeek/
/var/log/zeek-custom/

*.pcap
*.pcapng
*.cap

conn.log
dns.log
http.log
ssl.log
tls.log
notice.log
weird.log
files.log
software.log
x509.log

possible_malware.log
reverse_shell_live.log
reverse_shell_movement.log
reverse_shell_final.log

# Allow sanitized/sample Zeek evidence if explicitly named as sample
!**/*sample*.log
!**/*sample*.json
!**/*sanitized*.log
!**/*sanitized*.json


# ============================================================
# Wazuh runtime files and logs
# ============================================================

/var/ossec/logs/
/var/ossec/queue/
/var/ossec/var/
/var/ossec/tmp/
/var/ossec/stats/
/var/ossec/backup/

alerts.log
alerts.json
ossec.log
archives.log
archives.json

# Allow Wazuh config, decoders and rules
!blue-team/wazuh/**/*.xml
!blue-team/wazuh/**/*.conf
!blue-team/wazuh/**/*.md

# Allow sanitized evidence samples
!evidence/**/*sample*.json
!evidence/**/*sanitized*.json
!evidence/**/README.md


# ============================================================
# pfSense / RouterOS sensitive exports and backups
# ============================================================

config.xml
config-*.xml
*.backup.xml

*.rsc.backup
*.rsc.old

# Allow explicitly sanitized/example configs
!network/pfsense/config/config-sanitized.xml
!network/pfsense/config/config-example.xml
!network/routeros/config/routeros-config-example.rsc


