<group name="local,auditd,">

  <rule id="100700" level="13">
    <if_sid>80792</if_sid>
    <field name="audit.key">suid_exec</field>
    <description>Non-root user executed a root-effective command: $(audit.exe)</description>
    <group>privilege_escalation,suid,</group>
    <mitre>
      <id>T1548.001</id>
    </mitre>
  </rule>

  <rule id="100701" level="5">
    <if_sid>80792</if_sid>
    <field name="audit.key">root_exec</field>
    <description>Root command executed: $(audit.exe)</description>
    <group>root_execution,audit_command,</group>
  </rule>

  <rule id="100702" level="7">
    <if_sid>80792</if_sid>
    <field name="audit.key">sudo_exec</field>
    <description>sudo command executed by auid=$(audit.auid): $(audit.exe)</description>
    <group>privilege_escalation,sudo,</group>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <rule id="100703" level="7">
    <if_sid>80792</if_sid>
    <field name="audit.key">su_exec</field>
    <description>su command executed by auid=$(audit.auid): $(audit.exe)</description>
    <group>privilege_escalation,su,valid_accounts,</group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

  <rule id="100704" level="5">
    <if_sid>80792</if_sid>
    <field name="audit.key">download_exec</field>
    <description>execution from download folder: $(audit.exe) $(audit.comm)</description>
    <group>execution_from_download,</group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

</group>