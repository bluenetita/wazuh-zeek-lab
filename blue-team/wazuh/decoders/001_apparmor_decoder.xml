<!--
  Decoder AppArmor autonomo.
  Non modifica e non sostituisce il decoder auditd standard.
-->

<decoder name="apparmor_audit">
  <prematch type="pcre2">^(?:node=\S+\s+)?type=(?:AVC|USER_AVC|1400|1107)\b.*\bapparmor="</prematch>
</decoder>

<!-- Tipo del record Audit e ID evento -->
<decoder name="apparmor_audit">
  <parent>apparmor_audit</parent>
  <regex type="pcre2">type=([A-Z0-9_]+)\s+msg=audit\([^:]+:([0-9]+)\):</regex>
  <order>apparmor.audit_type,apparmor.audit_id</order>
</decoder>

<!-- Risultato AppArmor: ALLOWED, DENIED, STATUS ecc. -->
<decoder name="apparmor_audit">
  <parent>apparmor_audit</parent>
  <regex type="pcre2">apparmor="([^"]+)"</regex>
  <order>apparmor.event</order>
</decoder>

<!-- Operazione: open, capable, profile_load, signal ecc. -->
<decoder name="apparmor_audit">
  <parent>apparmor_audit</parent>
  <regex type="pcre2">operation="([^"]+)"</regex>
  <order>apparmor.operation</order>
</decoder>

<!-- Classe dell'oggetto -->
<decoder name="apparmor_audit">
  <parent>apparmor_audit</parent>
  <regex type="pcre2">class="([^"]+)"</regex>
  <order>apparmor.object_class</order>
</decoder>

<!-- Profilo che ha generato la decisione -->
<decoder name="apparmor_audit">
  <parent>apparmor_audit</parent>
